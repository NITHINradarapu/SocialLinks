rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // User Profile Document
    match /users/{userId} {
      // ANYONE can read a user's profile (needed for Public Profiles)
      allow read: if true;
      // ONLY the authenticated user who owns the profile can write to it,
      // and their profile username must match their claimed username mapping.
      allow write: if request.auth != null && request.auth.uid == userId
        && (
          !('username' in request.resource.data.profile) ||
          request.resource.data.profile.username == null ||
          get(/databases/$(database)/documents/usernames/$(request.resource.data.profile.username)).data.uid == userId
        );
      
      // Links Subcollection
      match /links/{linkId} {
        // ANYONE can read a user's links (needed for Public Profiles)
        allow read: if true;
        // ONLY the authenticated user who owns the links can write to them
        allow write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Usernames mapping collection
    match /usernames/{username} {
      // ANYONE can read to check availability
      allow read: if true;
      // ONLY the owner of the UID can create or delete the mapping
      allow write: if request.auth != null && (
        (request.method == 'create' && request.resource.data.uid == request.auth.uid) ||
        (request.method == 'delete' && resource.data.uid == request.auth.uid) ||
        (request.method == 'update' && resource.data.uid == request.auth.uid && request.resource.data.uid == request.auth.uid)
      );
    }
  }
}
